{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Rails server",
			"type": "shell",
			"command": "ruby .\\bin\\rails server",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Tailwind watch",
			"type": "shell",
			"command": "ruby .\\bin\\rails tailwindcss:watch",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Dev: Rails + Tailwind",
			"dependsOn": [
				"Rails server",
				"Tailwind watch"
			],
			"dependsOrder": "parallel",
			"group": "build"
		}
	]
}