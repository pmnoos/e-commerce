<%= form_for order, url: update_checkout_path(order.state), html: { id: "checkout_form_#{order.state}" } do |form| %>
  <% if order.state.in?(["payment", "confirm"]) %>
    <div class="digital-delivery-note" role="note" aria-label="Digital delivery notice">
      <strong>Digital delivery:</strong> No shipping is required for these products. Access is provided instantly after successful payment.
    </div>
  <% end %>

  <% if order.state == "address" || !order.email? %>
    <div class="text-input mb-6">
      <%= form.label :email, 'Customer email' %>
      <%= form.email_field :email, required: true, placeholder: 'name@example.com' %>
    </div>
  <% end %>

  <%= render "checkouts/steps/#{order.state}_step", form: form, differentiator: @differentiator %>
<% end %>
