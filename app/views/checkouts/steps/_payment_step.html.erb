<%
  payment_method_card_classes = "rounded-xl bg-white p-6 border-[1px] border-gray-mid mb-6 text-black dark:bg-black dark:border-gray-400 dark:text-sand"
  payment_method_top_label_classes = "flex items-center justify-between mb-6 cursor-pointer font-sans-md text-body-md"
  payment_method_fieldset_classes = "flex items-center justify-start gap-y-6"
  paypal_payment_method = @order.available_payment_methods.find { |payment_method| payment_method.type == "SolidusPaypalCommercePlatform::PaymentMethod" }
%>

<div class="payment-step" data-controller="checkout-payment">
  <div class="digital-delivery-note" role="note" aria-label="Digital delivery notice">
    <strong>Digital delivery:</strong> No shipping is required for these products. Access is provided instantly after successful payment.
  </div>

  <fieldset class="payment-step__payment mb-6 border-b-[1px] border-gray-mid">
    <legend class="font-serif text-h5 md:text-h4">
      <%= t('spree.payment_information') %>
    </legend>
    <% if @order.covered_by_store_credit? %>
      <p>Your order is fully covered by store credits, no additional payment method is required.</p>
    <% else %>
      <% available_payment_methods = @order.available_payment_methods.sort_by do |payment_method|
           payment_method.type == "SolidusPaypalCommercePlatform::PaymentMethod" ? 0 : 1
         end %>
      <ul class="payment-step__selector my-6">
        <% @wallet_payment_sources&.each do |wallet_payment_source| %>
          <% payment_method = wallet_payment_source.payment_source.payment_method %>
          <% default = wallet_payment_source == @default_wallet_payment_source %>
          <% fieldset_name = "wallet-source-#{wallet_payment_source.id}" %>

          <li class="<%= payment_method_card_classes %>">
            <label class="<%= payment_method_top_label_classes %>">
              <%= t(payment_method.name, scope: 'spree.payment_methods', default: payment_method.name) %>
              <%= radio_button_tag(
                "order[wallet_payment_source_id]",
                wallet_payment_source.id,
                default,
                'data-action': 'checkout-payment#paymentSelected',
                'data-checkout-payment-target': "paymentRadio",
                'data-fieldset-name': fieldset_name,
                id: ","
              ) %>
            </label>
            <fieldset name="<%= fieldset_name %>" class="payment-step__details <%= payment_method_fieldset_classes %>">
              <%= render(
                "checkouts/existing_payment/#{payment_method.partial_name}",
                wallet_payment_source: wallet_payment_source,
              ) %>
            </fieldset>
          </li>
        <% end %>

        <% available_payment_methods.each.with_index do |payment_method, index| %>
          <% default = !@default_wallet_payment_source && index.zero? %>
          <% fieldset_name = "payment-method-#{payment_method.id}" %>

          <li class="<%= payment_method_card_classes %>">
            <label class="<%= payment_method_top_label_classes %>">
              <%= t(payment_method.name, scope: 'spree.payment_method', default: payment_method.name) %>
              <%= radio_button_tag(
                "order[payments_attributes][][payment_method_id]",
                payment_method.id,
                default,
                'data-action': 'checkout-payment#paymentSelected',
                'data-checkout-payment-target': "paymentRadio",
                'data-fieldset-name': fieldset_name,
              ) %>
            </label>
            <fieldset name="<%= fieldset_name %>" class="payment-step__details <%= payment_method_fieldset_classes %>">
              <%= render(
                "checkouts/payment/#{payment_method.partial_name}",
                payment_method: payment_method,
              ) %>
            </fieldset>
          </li>
        <% end %>
      </ul>
    <% end %>
  </fieldset>

  <div id="paypal-checkout-message" class="hidden rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert" aria-live="polite"></div>

  <div class="flex justify-end py-6">
    <%= button_tag(
      I18n.t("spree.save_and_continue"),
      class: 'button-primary',
      name: :commit,
      id: 'checkout-payment-continue'
    ) %>
  </div>
</div>

<script>
  Solidus.disableSaveOnClick();

  const initializeCheckoutPaymentStep = () => {
    const checkoutForm = document.getElementById('checkout_form_payment');
    if (!checkoutForm) return;
    const paypalMessage = document.getElementById('paypal-checkout-message');
    const paypalStatus = document.getElementById('paypal-button-status');
    const continueButton = document.getElementById('checkout-payment-continue');

    const paypalMethodId = <%= paypal_payment_method&.id.to_json %>;
    if (!paypalMethodId) return;

    const updatePaypalState = () => {
      const selectedPaymentMethod = document.querySelector('input[name="order[payments_attributes][][payment_method_id]"]:checked');
      const paypalOrderIdInput = document.getElementById('payments_source_paypal_order_id');
      const paypalSelected = selectedPaymentMethod && selectedPaymentMethod.value === String(paypalMethodId);
      const approved = paypalOrderIdInput && paypalOrderIdInput.value.toString().trim().length > 0;

      if (continueButton) {
        continueButton.disabled = Boolean(paypalSelected && !approved);
        continueButton.classList.toggle('opacity-50', Boolean(paypalSelected && !approved));
        continueButton.classList.toggle('cursor-not-allowed', Boolean(paypalSelected && !approved));
      }

      if (paypalStatus) {
        if (paypalSelected && !approved) {
          paypalStatus.textContent = 'Approve payment with the PayPal button below. Checkout will continue automatically after approval.';
          paypalStatus.classList.remove('hidden');
        } else {
          paypalStatus.textContent = '';
          paypalStatus.classList.add('hidden');
        }
      }

      if (!paypalSelected && paypalMessage) {
        paypalMessage.classList.add('hidden');
        paypalMessage.textContent = '';
      }
    };

    document.addEventListener('change', (event) => {
      if (event.target && event.target.name === 'order[payments_attributes][][payment_method_id]') {
        updatePaypalState();
      }
    });

    document.addEventListener('paypal:approved', () => {
      if (paypalMessage) {
        paypalMessage.classList.add('hidden');
        paypalMessage.textContent = '';
      }
      updatePaypalState();
    });

    document.addEventListener('paypal:error', (event) => {
      const message = event.detail?.message || 'PayPal approval did not complete. Please try again.';

      if (paypalMessage) {
        paypalMessage.textContent = message;
        paypalMessage.classList.remove('hidden');
      }

      if (paypalStatus) {
        paypalStatus.textContent = message;
        paypalStatus.classList.remove('hidden');
      }

      updatePaypalState();
    });

    updatePaypalState();

    checkoutForm.addEventListener('submit', (event) => {
      const selectedPaymentMethod = document.querySelector('input[name="order[payments_attributes][][payment_method_id]"]:checked');
      if (!selectedPaymentMethod || selectedPaymentMethod.value !== String(paypalMethodId)) {
        if (paypalMessage) {
          paypalMessage.classList.add('hidden');
          paypalMessage.textContent = '';
        }
        return;
      }

      const paypalOrderIdInput = document.getElementById('payments_source_paypal_order_id');
      if (paypalOrderIdInput && paypalOrderIdInput.value.toString().trim().length > 0) return;

      event.preventDefault();
      if (paypalMessage) {
        paypalMessage.textContent = 'Please click the PayPal button and approve payment before continuing.';
        paypalMessage.classList.remove('hidden');
        paypalMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      updatePaypalState();
    });
  };

  if (document.readyState === 'loading') {
    window.addEventListener('DOMContentLoaded', initializeCheckoutPaymentStep);
  } else {
    initializeCheckoutPaymentStep();
  }
</script>
