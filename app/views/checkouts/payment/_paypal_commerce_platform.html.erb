<%= render partial: "solidus_paypal_commerce_platform/shared/javascript_sdk_tag", locals: {payment_method: payment_method} %>

<div class="space-y-3">
  <p class="text-sm text-gray-700 dark:text-gray-300">
    Use the PayPal button below to approve payment. After approval, checkout will continue automatically.
  </p>

  <div id="paypal-button-status" class="hidden rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800" role="status" aria-live="polite"></div>

  <div id="paypal-button-container"></div>

  <div data-pp-message data-pp-placement="payment" data-pp-amount="<%= @order.total %>"></div>

</div>

<input type="hidden" name="payment_source[<%= payment_method.id %>][paypal_order_id]" id="payments_source_paypal_order_id">
<input type="hidden" name="payment_source[<%= payment_method.id %>][paypal_email]" id="payments_source_paypal_email">
<input type="hidden" name="payment_source[<%= payment_method.id %>][paypal_funding_source]" id="payments_source_paypal_funding_source">

<script>
  SolidusPaypalCommercePlatform.api_key = "<%= spree_current_user.try(:spree_api_key) %>"
  SolidusPaypalCommercePlatform.current_order_id = "<%= @order.number %>"
  SolidusPaypalCommercePlatform.current_order_token = "<%= @order.guest_token %>"
</script>

<% unless payment_method.render_only_venmo_standalone? %>
  <script>
    const initializePaypalCheckoutButton = () => {
      const paypalButtonContainer = document.getElementById('paypal-button-container')
      if (!paypalButtonContainer || paypalButtonContainer.childElementCount > 0) return

      SolidusPaypalCommercePlatform.renderButton("<%= payment_method.id %>",<%= raw payment_method.button_style.to_json %>)

      window.setTimeout(() => {
        const refreshedButtonContainer = document.getElementById('paypal-button-container')
        const paypalStatus = document.getElementById('paypal-button-status')

        if (!refreshedButtonContainer || !paypalStatus) return
        if (refreshedButtonContainer.childElementCount > 0) return

        paypalStatus.textContent = 'The PayPal button did not load. Refresh the page and try again.'
        paypalStatus.classList.remove('hidden')
      }, 3000)
    }

    if (document.readyState === 'loading') {
      window.addEventListener('DOMContentLoaded', initializePaypalCheckoutButton)
    } else {
      initializePaypalCheckoutButton()
    }
  </script>
<% end %>

<% if payment_method.venmo_standalone_enabled? %>
  <script>
    const initializeVenmoStandaloneButton = () => {
      const paypalButtonContainer = document.getElementById('paypal-button-container')
      if (!paypalButtonContainer || paypalButtonContainer.childElementCount > 0) return

      SolidusPaypalCommercePlatform.renderVenmoStandalone("<%= payment_method.id %>",<%= raw payment_method.button_style.to_json %>)
    }

    if (document.readyState === 'loading') {
      window.addEventListener('DOMContentLoaded', initializeVenmoStandaloneButton)
    } else {
      initializeVenmoStandaloneButton()
    }
  </script>
<% end %>

<div id="paypal_commerce_platform_overlay"></div>
