<body class="bg-gradient-to-br from-rose-50 via-emerald-50 to-blue-50">
<section class="max-w-lg mx-auto px-4 py-8">

  <!-- Heading -->
  <div class="text-center mb-6">
    <h1 class="text-2xl font-serif font-semibold text-gray-800">
      Contact
    </h1>
    <p class="mt-2 text-sm text-gray-600">
      We'd love to hear from you — support, feedback, or just to say hello.
    </p>
  </div>

  <!-- Info Card -->
  <div class="rounded-xl p-4 mb-5
              bg-gradient-to-br from-emerald-100 via-pink-100 to-blue-100
              shadow-sm border border-white/40 backdrop-blur-sm">

    <!-- Support -->
    <div class="mb-4">
      <h2 class="text-sm font-semibold text-gray-800 mb-0.5">
        Customer Support
      </h2>
      <p class="text-sm text-gray-700">
        Email:
        <a href="mailto:digital.diary85@gmail.com"
           class="font-medium text-emerald-700 hover:underline">
          digital.diary85@gmail.com
        </a>
      </p>
    </div>

    <!-- Business -->
    <div class="mb-4">
      <h2 class="text-sm font-semibold text-gray-800 mb-0.5">
        Business Information
      </h2>
      <p class="text-sm text-gray-700">
        Digital Apps Store — Food Track, Diary, Autobiography &amp; Term Deposit
      </p>
    </div>

    <!-- Response -->
    <div>
      <h2 class="text-sm font-semibold text-gray-800 mb-0.5">
        Response Times
      </h2>
      <p class="text-sm text-gray-700">
        We generally respond within
        <span class="font-semibold text-gray-800">24 hours</span>.
      </p>
    </div>

  </div>

  <!-- Contact Form -->
  <div class="rounded-xl p-4
              bg-white/70 backdrop-blur-md
              border border-emerald-200
              shadow-md">

    <h2 class="text-base font-semibold text-gray-800 mb-3">
      Send a Message
    </h2>

    <form action="#" method="post" class="space-y-3">

      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">
          Your Name
        </label>
        <input type="text"
               class="w-full rounded-md border border-emerald-200 bg-white/80 px-2.5 py-1.5 text-sm
                      focus:ring-2 focus:ring-emerald-300 focus:outline-none">
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">
          Email Address
        </label>
        <input type="email"
               class="w-full rounded-md border border-emerald-200 bg-white/80 px-2.5 py-1.5 text-sm
                      focus:ring-2 focus:ring-emerald-300 focus:outline-none">
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">
          Message
        </label>
        <textarea rows="3"
                  class="w-full rounded-md border border-emerald-200 bg-white/80 px-2.5 py-1.5 text-sm
                         focus:ring-2 focus:ring-emerald-300 focus:outline-none"></textarea>
      </div>

      <button type="submit"
              class="px-4 py-1.5 rounded-md text-sm
                     bg-gradient-to-r from-emerald-300 to-green-200
                     text-gray-800 font-semibold
                     hover:from-green-200 hover:to-emerald-300
                     transition shadow-sm">
        Send Message
      </button>

    </form>
  </div>

</section>

