
<!-- Two Column Layout - Centered -->
<div class="w-full py-8">
<div class="flex justify-center">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch mt-8 max-w-4xl w-full px-4">

  

  <!-- LEFT: Info Card -->
  <div class="h-full rounded-2xl p-6
              bg-white/60 backdrop-blur-md
              border border-white/40
              shadow-md
              transition hover:-translate-y-1 hover:shadow-lg">

    <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
      <i class="bi bi-info-circle me-2 text-emerald-500"></i>
      Contact Information
    </h2>

    <div class="space-y-4 text-sm text-gray-700">

      <div>
        <p class="font-semibold text-gray-800">Customer Support</p>
        <a href="mailto:digital.diary85@gmail.com"
           class="hover:underline" style="color: var(--brand);">
          digital.diary85@gmail.com
        </a>
      </div>

      <div>
        <p class="font-semibold text-gray-800">Business</p>
        <p>
          Digital Apps Store — Food Track, Diary, Autobiography &amp; Term Deposit
        </p>
      </div>

      <div>
        <p class="font-semibold text-gray-800">Response Time</p>
        <p>
          Within <span class="font-semibold">24 hours</span>
        </p>
      </div>

    </div>
  </div>

  <!-- RIGHT: Form -->
  <div class="h-full rounded-2xl p-6
              bg-gradient-to-br from-white/70 to-emerald-50/60
              backdrop-blur-md
              border border-emerald-100
              shadow-[0_10px_25px_rgba(53,95,46,0.22)]
              transition hover:-translate-y-1 hover:shadow-[0_14px_32px_rgba(53,95,46,0.30)]">

    <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
      <i class="bi bi-envelope me-2 text-emerald-500"></i>
      Send a Message
    </h2>

    <form action="<%= contact_submit_path %>" method="post" class="space-y-4">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Your Name
        </label>
        <input type="text" name="name"
          class="w-full rounded-xl border border-emerald-100 bg-white/80 px-3 py-2 text-sm
                 focus:ring-2 focus:ring-emerald-300 focus:outline-none">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Email Address
        </label>
        <input type="email" name="email"
          class="w-full rounded-xl border border-emerald-100 bg-white/80 px-3 py-2 text-sm
                 focus:ring-2 focus:ring-emerald-300 focus:outline-none">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Message
        </label>
        <textarea name="message" rows="4"
          class="w-full rounded-xl border border-emerald-100 bg-white/80 px-3 py-2 text-sm
                 focus:ring-2 focus:ring-emerald-300 focus:outline-none"></textarea>
      </div>

      <button type="submit"
        class="w-full py-2 rounded-xl text-sm font-semibold text-white transition shadow-sm hover:opacity-95"
        style="background: var(--brand);">
        Send Message
      </button>

    </form>
  </div>

</div>
</div>