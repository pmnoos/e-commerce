<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <span>&copy; <%= Time.current.year %> Digital Apps Store. All rights reserved.</span>
      <%= link_to "Privacy", privacy_path, class: "text-sm text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white" %>
      <%= link_to "Terms", terms_path, class: "text-sm text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white" %>
      <%= link_to "Refunds", refunds_path, class: "text-sm text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white" %>
      <%= link_to "Contact", contact_path, class: "text-sm text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white" %>
      <%= link_to "https://solidus.io", class: "text-sm text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white", target: "_blank", rel: "noopener noreferrer" do %>
        Built with Solidus
      <% end %>
    </div>
    <%
      store = (defined?(current_store) && current_store) || (defined?(Spree::Store) ? Spree::Store.default : nil)
      available_locales = Array(store&.available_locales).map do |locale|
        [
          I18n.t('spree.i18n.this_file_language',
          locale: locale,
          default: locale.to_s,
          fallback: false), locale
        ]
      end.sort
    %>
    <% if available_locales.many? %>
      <div class="locale-selector" data-controller="locale-selector">
        <%= form_tag select_locale_path do %>
          <div class="locale-selector__select-input select-input">
            <%= label_tag :switch_to_locale, "#{t('spree.i18n.language')}:" %>
            <%= select_tag(:switch_to_locale, options_for_select(available_locales, I18n.locale), data: { action: "locale-selector#submitForm", "locale-selector-target" => "selector" }) %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</footer>
