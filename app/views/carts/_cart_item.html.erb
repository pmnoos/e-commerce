<% variant = line_item.variant %>
<%
  cart_themes = {
    "my-diary-app"         => { icon: "📖", accent: "#4a7c59", bg: "#eaf3ec",
                                 blurb: "Your private daily journal — capture thoughts, moods, and goals." },
    "autobiography-app"    => { icon: "✍️",  accent: "#7c4a1e", bg: "#f5ede3",
                                 blurb: "Turn your life experiences into a structured personal narrative." },
    "term-deposit-tracker" => { icon: "💰", accent: "#2a5c8a", bg: "#e3eef7",
                                 blurb: "Track deposits, interest rates, and maturity dates in one place." },
    "grocery-expense-tracker" => { icon: "🛒", accent: "#8a5a2a", bg: "#f6ede2",
                                 blurb: "Food Track: log purchases, compare stores, and monitor price trends over time." }
  }
  ct = cart_themes[variant.product.slug] || { icon: "📦", accent: "#355f2e", bg: "#eaf3ec", blurb: variant.product.name }
%>

<%= order_form.fields_for :line_items, line_item do |item_form| %>
  <article class="cart-item py-6 border-b-[1px] border-b-gray-200 grid-container">
    <div class="cart-item-thumb col-span-1 md:col-span-3" style="background:<%= ct[:bg] %>; border-radius: 12px; padding: 0.75rem; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.35rem; min-width:60px; min-height:60px;">
      <%= link_to variant.product do %>
        <span style="font-size:1.8rem; line-height:1;"><%= ct[:icon] %></span>
        <p class="cart-item-blurb" style="color:<%= ct[:accent] %>"><%= ct[:blurb] %></p>
      <% end %>
    </div>

    <div class="flex justify-between items-start col-span-3 md:col-span-5">
      <%= render(
        'orders/item_info',
        line_item: line_item,
        variant: variant,
        classes: ['cart-item__info']
      ) %>
      <div class="cart-item__price md:hidden col-span-2">
        <p class="font-sans-md"><%= line_item.display_amount.to_html unless line_item.quantity.nil? %></p>
      </div>
    </div>

    <div class="flex flex-row-reverse justify-between col-span-full sm:col-span-4 sm:flex-col">
      <div class="flex items-center justify-between w-full">
        <div class="cart-item__quantity text-input mr-4">
          <%= item_form.number_field :quantity %>
        </div>

        <div class="cart-item__price hidden md:block col-span-2">
          <p class="font-sans-md"><%= line_item.display_amount.to_html unless line_item.quantity.nil? %></p>
        </div>

        <div class="flex items-center justify-end md:hidden gap-x-2">
          <%= render 'carts/cart_item_remove', order_form: order_form, item_form: item_form, line_item: line_item %>
        </div>
      </div>

      <div class="hidden md:flex items-center justify-end gap-x-2">
        <%= render 'carts/cart_item_remove', order_form: order_form, item_form: item_form, line_item: line_item %>
      </div>
    </div>
  </article>
<% end %>
