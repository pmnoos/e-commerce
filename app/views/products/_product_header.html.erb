<% product_urls = {
  "autobiography app" => "https://www.autobiography.live",
  "my diary app" => "https://pmnoos.github.io/diary_app-landing/",
  "diary app" => "https://pmnoos.github.io/diary_app-landing/"
} %>
<% display_name = product.name.to_s.tr("_", " ").titleize %>
<% display_name = "Diary App" if display_name.casecmp("My Diary App").zero? %>
<% product_url = product_urls[display_name.downcase] %>

<header class="product-header">
  <h1 class="font-serif-md text-h4 lg:text-h3 mt-12 mb-3 lg:mt-3" itemprop="name">
    <% if product_url %>
      <a href="<%= product_url %>" target="_blank" rel="noopener noreferrer"><%= display_name %></a>
    <% else %>
      <%= display_name %>
    <% end %>
  </h1>

  <% if product.price_for_options(current_pricing_options)&.money and !product.price.nil? %>
    <div class="product-price-card">
      <p class="product-price-kicker">Simple pricing</p>

      <h2 class="font-sans-md text-body-md" id="product-price">
        <%= content_tag(
          :span,
          display_price(product),
          itemprop: 'price',
          content: product.price_for_options(current_pricing_options)&.money.to_d,
          data: { js: 'price' }
        ) %>

        <%= content_tag(
          :span,
          nil,
          itemprop: 'priceCurrency',
          content: current_pricing_options.currency
        ) %>
      </h2>

      <div class="product-purchase-notes" aria-label="Purchase details">
        <p>One-time purchase. No subscription.</p>
        <p>Instant digital access after purchase.</p>
      </div>
    </div>
  <% end %>
</header>
