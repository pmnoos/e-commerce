<%
  home_meta_title = "Term Deposit Tracker and Practical Digital Apps"
  home_meta_description = "Start with Term Deposit Tracker to stay ahead of maturity dates, rates, and rollover decisions, then explore practical apps for groceries, diary writing, and autobiography planning."
  home_meta_image = "#{request.base_url}/storefront_favicon.svg"
%>
<% content_for :title, home_meta_title %>

<% content_for :head do %>
  <meta name="description" content="<%= home_meta_description %>">
  <meta name="keywords" content="term deposit tracker, maturity date tracker, rollover planning, grocery expense tracker, diary app, autobiography app, digital apps store">
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= home_meta_title %>">
  <meta property="og:description" content="<%= home_meta_description %>">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:image" content="<%= home_meta_image %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= home_meta_title %>">
  <meta name="twitter:description" content="<%= home_meta_description %>">
  <meta name="twitter:image" content="<%= home_meta_image %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
<% end %>

<section class="storefront-page">
  <% admin_user = spree_current_user&.has_spree_role?("admin") %>
  <% admin_link = admin_user ? "/admin" : switch_admin_login_path %>

  <section class="hero-shell">
    <div class="hero-content">
      <span class="pill">Lead Product: Term Deposit Tracker</span>
      <h1>Stop Missing Maturity Dates and Weak Rollover Decisions.</h1>
      <p>Term Deposit Tracker is the clearest starting point in the store: a focused tool for people managing savings across banks, terms, and maturity dates. See every deposit in one place, compare rates properly, and make your next move with more confidence.</p>
      <div class="actions">
        <a class="btn btn-primary" href="/products/term-deposit-tracker">View Term Deposit Tracker</a>
        <a class="btn btn-secondary" href="#catalog">Browse All Apps</a>
      </div>
    </div>
    <div class="hero-panel" aria-hidden="true">
      <div class="stat-card">
        <h3>Best For</h3>
        <p>Savers tracking multiple deposits and rollover dates</p>
      </div>
      <div class="stat-card">
        <h3>Core Outcome</h3>
        <p>Better visibility before deposits mature or underperform</p>
      </div>
    </div>
  </section>

  <section class="featured-focus" aria-label="Featured product">
    <div class="featured-copy">
      <div class="section-head">
        <h2>Start with the App Most Likely to Pay for Itself</h2>
        <p>Term Deposit Tracker is the most direct value offer in the catalog. One missed maturity date, forgotten deposit, or weak rollover choice can cost more than the app.</p>
      </div>
      <div class="featured-points">
        <article class="featured-point">
          <h3>See every deposit in one place</h3>
          <p>Track balances, institutions, rates, terms, and maturity dates without relying on scattered spreadsheets or memory.</p>
        </article>
        <article class="featured-point">
          <h3>Stay ahead of deadlines</h3>
          <p>Reduce the chance of money rolling into the wrong rate because you noticed the maturity too late.</p>
        </article>
        <article class="featured-point">
          <h3>Make rollover choices with numbers</h3>
          <p>Compare rates and review reinvestment scenarios before you lock in your next decision.</p>
        </article>
      </div>
    </div>
    <aside class="featured-panel">
      <span class="featured-badge">One-time purchase</span>
      <h3>Term Deposit Tracker</h3>
      <p class="featured-price">$24</p>
      <p>Built for self-directed savers, retirees managing cash reserves, and anyone laddering term deposits across institutions.</p>
      <div class="actions">
        <a class="btn btn-primary" href="/products/term-deposit-tracker">See Product Page</a>
        <a class="btn btn-secondary" href="https://pmnoos.github.io/term-tracker/" target="_blank" rel="noopener noreferrer">Open App Details</a>
      </div>
    </aside>
  </section>

  <section class="portal-nav" aria-label="Primary navigation">
    <div class="section-head">
      <h2>Store Access</h2>
      <p>Use the customer path to browse and buy. The admin path remains available for catalog and order management.</p>
    </div>
    <div class="portal-grid">
      <article class="portal-card">
        <h3>Shopper Portal</h3>
        <p>Browse categories, open product pages, and purchase apps through checkout.</p>
        <a class="btn btn-primary" href="/products">Browse Products</a>
      </article>
      <article class="portal-card">
        <h3><%= spree_current_user ? "My Account" : "Customer Login" %></h3>
        <p><%= spree_current_user ? "View orders, profile details, and account settings." : "Sign in to track purchases and manage your account." %></p>
        <a class="btn btn-secondary" href="<%= spree_current_user ? account_path : login_path %>"><%= spree_current_user ? "Open Account" : "Sign In" %></a>
      </article>
      <article class="portal-card <%= admin_user ? "portal-card-admin" : "" %>">
        <h3>Admin Portal</h3>
        <p><%= admin_user ? "Add or edit products, manage pricing, and review orders in the dashboard." : "Admin tools for catalog and order management." %></p>
        <a class="btn <%= admin_user ? "btn-primary" : "btn-secondary" %>" href="<%= admin_link %>"><%= admin_user ? "Open Admin Dashboard" : "Admin Login" %></a>
      </article>
    </div>
  </section>

  <% app_cards = [
       {
         title: "Term Deposit Tracker",
         description: "Track maturity dates, rates, institutions, and reinvestment decisions in one focused savings tool.",
         slug: "term-deposit-tracker"
       },
       {
         title: "Diary App",
         description: "Django-based private diary with entries, image uploads, reminders, and installable PWA support.",
         slug: "my-diary-app"
       },
       {
         title: "Autobiography App",
         description: "Shape life stories into structured chapters, organise memories, and build a long-form personal narrative with clarity.",
         slug: "autobiography-app"
       },
       {
         title: "Food Track App",
         description: "Log grocery purchases, compare stores, analyse price history, and review spending trends across your household budget.",
         slug: "grocery-expense-tracker"
       }
     ] %>

  <section class="info-grid">
    <% app_cards.each do |card| %>
      <a class="info-card block" href="/products/<%= card[:slug] %>">
        <h3><%= card[:title] %></h3>
        <p><%= card[:description] %></p>
      </a>
    <% end %>
  </section>

  <section class="steps" aria-label="How it works">
    <h2>Why Lead with Term Deposit Tracker</h2>
    <div class="steps-grid">
      <article class="step-card">
        <span class="step-index">1</span>
        <h3>Clear financial pain point</h3>
        <p>Customers immediately understand the risk of missed maturity dates, weak rates, and poorly timed rollovers.</p>
      </article>
      <article class="step-card">
        <span class="step-index">2</span>
        <h3>Easy value case</h3>
        <p>A $24 one-time purchase is easy to justify when a single avoidable mistake can cost more than that.</p>
      </article>
      <article class="step-card">
        <span class="step-index">3</span>
        <h3>Strong first product</h3>
        <p>Once the lead offer is clear, the rest of the catalog reads as additional practical tools rather than unrelated apps.</p>
      </article>
    </div>
  </section>

  <% product_urls = {
    "autobiography app" => "https://www.autobiography.live",
    "my diary app" => django_diary_landing_path,
    "diary app" => django_diary_landing_path,
    "term tracker" => "https://pmnoos.github.io/term-tracker/",
    "term deposit tracker" => "https://pmnoos.github.io/term-tracker/",
    "grocery expense tracker" => "https://pmnoos.github.io/food-costs/",
    "food track app" => "https://pmnoos.github.io/food-costs/"
  } %>


  <section id="catalog" class="catalog-wrap">
    <div class="section-head">
      <h2>Explore the Full Catalog</h2>
      <p>Start with Term Deposit Tracker, then explore the rest of the store for grocery tracking, diary writing, and autobiography planning.</p>
      <p>Each app is a focused one-time purchase product built for a specific job instead of a bloated subscription bundle.</p>
    </div>

    <div class="catalog">
    <% product_icons = {
          "diary app"               => { icon: "📖", accent: "#4a7c59", bg: "#eaf3ec" },
          "autobiography app"       => { icon: "✍️",  accent: "#7c4a1e", bg: "#f5ede3" },
          "term deposit tracker"    => { icon: "💰", accent: "#2a5c8a", bg: "#e3eef7" },
          "grocery expense tracker" => { icon: "🛒", accent: "#8a5a2a", bg: "#f6ede2" }
       } %>
    <% @products.each do |product| %>
      <% display_name = product.name.to_s.tr("_", " ").titleize %>
      <% display_name = "Diary App" if display_name.casecmp("My Diary App").zero? %>
      <% app_url = product_urls[display_name.downcase] %>
      <% product_path = "/products/#{product.slug}" %>
      <% excerpt = truncate(strip_tags(product.description.to_s), length: 180, separator: " ") %>
      <% pi = product_icons[display_name.downcase] || { icon: "📦", accent: "#355f2e", bg: "#eaf3ec" } %>
      <article class="card">
        <a href="<%= product_path %>" class="card-banner" style="background:<%= pi[:bg] %>; color:<%= pi[:accent] %>" aria-hidden="true">
          <span class="card-banner-icon"><%= pi[:icon] %></span>
        </a>
        <h2>
          <a href="<%= product_path %>"><%= display_name %></a>
        </h2>
        <% if product.price.present? %>
          <div class="price"><%= number_to_currency(product.price) %></div>
        <% end %>
        <p class="desc"><%= excerpt %></p>
        <a class="read-more" href="<%= product_path %>">Read more</a>
        <div class="card-actions">
          <a class="btn btn-primary" href="<%= product_path %>">Buy in Store</a>
          <% if app_url %>
            <% internal_details_link = app_url.to_s.start_with?("/") %>
            <a class="btn btn-secondary" href="<%= app_url %>" <%= internal_details_link ? "" : 'target="_blank" rel="noopener noreferrer"'.html_safe %>>App Details</a>
          <% end %>
        </div>
      </article>
    <% end %>

    </div>
  </section>

  <section class="cta">
    <h2>Start with the Strongest Offer</h2>
    <p>Lead with Term Deposit Tracker if you want the clearest value proposition, then use the rest of the catalog as supporting products.</p>
    <a class="btn btn-primary" href="/products/term-deposit-tracker">View Term Deposit Tracker</a>
  </section>
</section>
